{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Effect": "Allow",
            "Principal": {
                "AWS": [
                    "arn:aws:iam::<AWS_ACCOUNT_ID>:role/<ROLE_1>",
                    "arn:aws:iam::<AWS_ACCOUNT_ID>:role/<ROLE_2>"
                ]
            },
            "Action": [
                "codeartifact:GetAuthorizationToken",
                "codeartifact:PublishPackageVersion"
            ],
            "Resource": "*"
        }
    ]
}
